    "deploy:supabase:seed": "node scripts/deploy-to-supabase.js --seed",
    "deploy:supabase:all": "node scripts/deploy-to-supabase.js --all",
    "deploy:supabase:dry-run": "node scripts/deploy-to-supabase.js --dry-run",
    "export:db-polish": "node scripts/export-db-polish.js",
